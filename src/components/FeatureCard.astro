---
/**
 * FeatureCard - A card component with hover effects
 * Inspired by Biome website design
 */

interface Props {
  title: string;
  icon?: string;
  href?: string;
}

const { title, icon, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="feature-card" href={href}>
  {icon && <span class="feature-card-icon">{icon}</span>}
  <h3 class="feature-card-title">{title}</h3>
  <div class="feature-card-body">
    <slot />
  </div>
</Tag>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--q-space-3, 0.75rem);
    padding: var(--q-space-6, 1.5rem);
    background: rgba(23, 24, 28, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(233, 30, 99, 0.35);
    border-radius: var(--q-radius-lg, 0.75rem);
    box-shadow: 0 0 20px rgba(233, 30, 99, 0.1);
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--q-transition-normal, 200ms ease),
      border-color var(--q-transition-normal, 200ms ease),
      box-shadow var(--q-transition-normal, 200ms ease),
      background var(--q-transition-normal, 200ms ease);
  }

  .feature-card:hover {
    transform: translateY(-2px);
    border-color: var(--sl-color-accent, #E91E63);
    box-shadow: 0 0 30px rgba(233, 30, 99, 0.2);
    background: rgba(23, 24, 28, 0.95);
  }

  .feature-card-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .feature-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--q-gray-8, #f4f4f5);
    margin: 0;
  }

  .feature-card-body {
    color: var(--q-gray-6, #98989f);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Light mode */
  :root[data-theme='light'] .feature-card {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(194, 24, 91, 0.3);
    box-shadow: 0 0 20px rgba(194, 24, 91, 0.08);
  }

  :root[data-theme='light'] .feature-card:hover {
    background: rgba(255, 255, 255, 0.95);
    border-color: var(--sl-color-accent, #C2185B);
    box-shadow: 0 0 30px rgba(194, 24, 91, 0.15);
  }

  :root[data-theme='light'] .feature-card-title {
    color: var(--q-gray-1, #020202);
  }

  :root[data-theme='light'] .feature-card-body {
    color: var(--q-gray-5, #64646c);
  }

  /* Blue palette mode */
  :global(body.blue-palette) .feature-card {
    border-color: rgba(52, 71, 255, 0.35);
    box-shadow: 0 0 20px rgba(52, 71, 255, 0.1);
  }

  :global(body.blue-palette) .feature-card:hover {
    border-color: #3447ff;
    box-shadow: 0 0 30px rgba(52, 71, 255, 0.2);
  }

  :global(:root[data-theme='light'] body.blue-palette) .feature-card {
    border-color: rgba(0, 101, 218, 0.3);
    box-shadow: 0 0 20px rgba(0, 101, 218, 0.08);
  }

  :global(:root[data-theme='light'] body.blue-palette) .feature-card:hover {
    border-color: #0065da;
    box-shadow: 0 0 30px rgba(0, 101, 218, 0.15);
  }
</style>
