---
/**
 * TrustBar - Horizontal bar of compliance badges
 * FIPS standards + RFC specs
 */
---

<section class="trust-bar not-content">
  <div class="trust-inner">
    <span class="trust-label">Standards</span>
    <div class="trust-badges">
      <span class="badge badge-fips">FIPS 203 <span class="badge-sub">ML-KEM</span></span>
      <span class="badge badge-fips">FIPS 204 <span class="badge-sub">ML-DSA</span></span>
      <span class="badge badge-fips">FIPS 205 <span class="badge-sub">SLH-DSA</span></span>
      <span class="badge-sep"></span>
      <span class="badge badge-rfc">RFC 5280</span>
      <span class="badge badge-rfc">RFC 6960</span>
      <span class="badge badge-rfc">RFC 3161</span>
      <span class="badge badge-rfc">RFC 5652</span>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.25rem 1.5rem;
    margin: 0 auto;
    max-width: 900px;
  }

  .trust-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .trust-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sl-color-gray-4);
    font-weight: 600;
  }

  .trust-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .badge {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    white-space: nowrap;
    transition: all var(--q-transition-normal, 0.2s ease);
  }

  .badge-fips {
    border: 1px solid rgba(255, 85, 163, 0.25);
    color: var(--sl-color-accent-high);
    background: rgba(255, 85, 163, 0.05);
  }

  .badge-fips:hover {
    border-color: rgba(255, 85, 163, 0.5);
    background: rgba(255, 85, 163, 0.1);
  }

  .badge-sub {
    color: var(--sl-color-gray-3);
    font-weight: 400;
    margin-left: 2px;
  }

  .badge-rfc {
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    background: transparent;
  }

  .badge-rfc:hover {
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-2);
  }

  .badge-sep {
    width: 1px;
    height: 1.25rem;
    background: var(--sl-color-gray-5);
    margin: 0 0.25rem;
  }

  /* Light mode */
  :root[data-theme='light'] .trust-bar {
    border-color: rgba(0, 0, 0, 0.06);
  }

  :root[data-theme='light'] .badge-fips {
    background: rgba(255, 85, 163, 0.04);
  }

  @media (max-width: 640px) {
    .trust-label {
      width: 100%;
      text-align: center;
    }
    .badge-sep {
      display: none;
    }
  }
</style>
