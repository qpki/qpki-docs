---
/**
 * QentriQ Landing Page
 * Redesigned with Biome-inspired design system
 */
import FeatureCard from '../components/FeatureCard.astro';
import CardGrid from '../components/CardGrid.astro';
import StandardBadge from '../components/StandardBadge.astro';
import Header from '../components/Header.astro';
import ColorSwitcher from '../components/ColorSwitcher.astro';
import '../styles/tokens.css';
import '../styles/landing.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="QentriQ - Quantum-Safe PKI Toolkit in Go. Build and deploy post-quantum X.509 infrastructure with ML-DSA, ML-KEM, and hybrid certificates." />
  <title>QentriQ - Quantum-Safe PKI Toolkit in Go</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="landing-page">
  <Header />

  <!-- Hero -->
  <section class="landing-hero landing-hero--centered">
    <div class="landing-hero-content">
      <h1 class="animate-in">Quantum is coming.<br/>Are you ready?</h1>
      <p class="animate-in" style="animation-delay: 0.1s">
        Build and deploy post-quantum X.509 infrastructure with ML-DSA, ML-KEM,
        and hybrid certificates. Open source. Standards-compliant, interoperable, CLI-first.
      </p>
      <div class="landing-buttons animate-in" style="animation-delay: 0.2s">
        <a href="/qpki/getting-started/quick-start/" class="btn btn-primary">
          Get Started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="https://github.com/qentriq" class="btn btn-secondary">
          View on GitHub
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Now -->
  <section class="landing-section">
    <h2>Why Now?</h2>
    <CardGrid columns={3}>
      <FeatureCard title="2030 Deadline" icon="🕐">
        Quantum computers will break RSA and ECC. Major organizations are already preparing.
      </FeatureCard>
      <FeatureCard title="Harvest Now, Decrypt Later" icon="📦">
        Encrypted data stolen today can be decrypted when quantum computers arrive.
      </FeatureCard>
      <FeatureCard title="Standards Ready" icon="✅">
        NIST finalized post-quantum standards in 2024. The tools exist. Time to act.
      </FeatureCard>
    </CardGrid>
  </section>

  <!-- The Solution -->
  <section class="landing-section">
    <h2>Learn. Build. Deploy.</h2>
    <CardGrid columns={2}>
      <FeatureCard title="QLAB" icon="🎓" href="/qlab/overview/">
        Hands-on learning journey. Understand quantum threats and build your first post-quantum certificate.
      </FeatureCard>
      <FeatureCard title="QPKI" icon="🔧" href="/qpki/getting-started/quick-start/">
        Experiment with post-quantum PKI. Learn by doing. CA, OCSP, TSA, CMS in a single binary.
      </FeatureCard>
    </CardGrid>
  </section>

  <!-- Features -->
  <section class="landing-section">
    <h2>Features</h2>
    <CardGrid columns={4}>
      <FeatureCard title="Post-Quantum Ready" icon="🔐">
        ML-DSA, ML-KEM, SLH-DSA. FIPS 203/204/205 compliant algorithms ready for the quantum era.
      </FeatureCard>
      <FeatureCard title="Hybrid Certificates" icon="🔄">
        Catalyst mode for dual-algorithm certificates. Smooth migration from classical to post-quantum.
      </FeatureCard>
      <FeatureCard title="CLI-First" icon="⚡">
        Single binary, no dependencies. Script everything. Perfect for automation and DevOps.
      </FeatureCard>
      <FeatureCard title="Battle-Tested" icon="✓">
        Cross-validated with OpenSSL and BouncyCastle. Standards-compliant X.509 certificates.
      </FeatureCard>
    </CardGrid>
  </section>


  <!-- Standards -->
  <section class="landing-section">
    <h2>Standards Compliant</h2>
    <p>Built on NIST post-quantum cryptography standards and industry PKI specifications.</p>
    <div class="landing-standards-grid stagger-children">
      <StandardBadge>FIPS 203 (ML-KEM)</StandardBadge>
      <StandardBadge>FIPS 204 (ML-DSA)</StandardBadge>
      <StandardBadge>FIPS 205 (SLH-DSA)</StandardBadge>
      <StandardBadge variant="default">RFC 5280 (X.509)</StandardBadge>
      <StandardBadge variant="default">RFC 6960 (OCSP)</StandardBadge>
      <StandardBadge variant="default">RFC 3161 (TSA)</StandardBadge>
      <StandardBadge variant="default">RFC 5652 (CMS)</StandardBadge>
    </div>
  </section>

  <!-- Footer -->
  <footer class="landing-footer">
    <p>
      Open source under Apache 2.0 license.
      <a href="https://github.com/qentriq">Contribute on GitHub</a>
    </p>
  </footer>

  <ColorSwitcher />
</body>
</html>
